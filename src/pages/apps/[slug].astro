---
import DownloadButton from "../../components/DownloadButton";
import ProductVisual from "../../components/ProductVisual.astro";
import { apps, getApp } from "../../data/site";
import SiteLayout from "../../layouts/SiteLayout.astro";

export function getStaticPaths() {
  return apps.map((app) => ({ params: { slug: app.slug } }));
}

const app = getApp(Astro.params.slug ?? "");

if (!app) {
  return Astro.redirect("/apps/");
}
---

<SiteLayout title={`${app.name} | Xueyang Song`} description={app.shortDescription}>
  <section class="atlas-shell border-b border-[var(--line)]">
    <div class="container-shell relative z-10 grid gap-10 py-14 lg:grid-cols-[0.86fr_1.14fr] lg:items-center lg:py-20">
      <div class="reveal-rise">
        <a href="/apps/" class="focus-ring atlas-link rounded-sm text-sm font-black">
          Apps
        </a>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <h1 class="text-5xl font-semibold leading-tight text-[var(--ink)] sm:text-6xl">{app.name}</h1>
          <span class="status-pill">coming soon</span>
        </div>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--muted)] sm:text-xl">{app.shortDescription}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <DownloadButton
            client:load
            repo={app.repo}
            status={app.versionStatus}
            assetPatterns={app.releaseAssets}
            fallbackUrl={app.repo}
            label={app.primaryCta}
          />
          <a href={app.repo} class="focus-ring secondary-cta" target="_blank" rel="noreferrer">
            {app.secondaryCta}
          </a>
        </div>
      </div>
      <div class="reveal-rise">
        <ProductVisual app={app} />
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <aside class="atlas-panel p-6 lg:sticky lg:top-24 lg:self-start">
        <div class="relative z-10">
          <p class="atlas-kicker">Status board</p>
          <h2 class="mt-4 text-2xl font-semibold text-[var(--ink)]">Release state</h2>
          <dl class="mt-7 space-y-6">
            <div>
              <dt class="text-xs font-black uppercase tracking-[0.14em] text-[var(--faint)]">Release</dt>
              <dd class="mt-1 text-sm font-bold text-[#ffd4ac]">Signed downloads coming soon</dd>
            </div>
            <div>
              <dt class="text-xs font-black uppercase tracking-[0.14em] text-[var(--faint)]">Platforms</dt>
              <dd class="mt-3 flex flex-wrap gap-2">
                {app.platforms.map((platform) => (
                  <span class="signal-chip">{platform}</span>
                ))}
              </dd>
            </div>
            <div>
              <dt class="text-xs font-black uppercase tracking-[0.14em] text-[var(--faint)]">Repository</dt>
              <dd class="mt-2">
                <a class="focus-ring atlas-link rounded-sm text-sm font-bold" href={app.repo} target="_blank" rel="noreferrer">
                  GitHub source
                </a>
              </dd>
            </div>
          </dl>
        </div>
      </aside>

      <div class="grid gap-7">
        <article class="data-card p-6">
          <p class="atlas-kicker">Why I'm building it</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-[var(--ink)]">{app.audience}</h2>
          <p class="mt-5 text-lg leading-8 text-[var(--muted)]">{app.positioning}</p>
        </article>

        <article class="data-card p-6">
          <p class="atlas-kicker">Capabilities</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {app.features.map((feature) => (
              <div class="rounded-lg border border-[var(--line)] bg-white/[0.035] p-4 transition hover:border-[var(--teal)]">
                <p class="text-sm font-medium leading-6 text-[var(--muted)]">{feature}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="data-card p-6">
          <p class="atlas-kicker">Workflow trace</p>
          <ol class="mt-6 grid gap-3">
            {app.workflow.map((step, index) => (
              <li class="grid gap-4 rounded-lg border border-[var(--line)] bg-white/[0.035] p-4 sm:grid-cols-[3rem_1fr] sm:items-center">
                <span class="flex h-10 w-10 items-center justify-center rounded-md bg-[var(--teal)] text-sm font-black text-[#031115]">
                  {index + 1}
                </span>
                <span class="text-sm font-medium leading-6 text-[var(--muted)]">{step}</span>
              </li>
            ))}
          </ol>
        </article>

        <article class="atlas-panel p-6">
          <div class="relative z-10 flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="atlas-kicker">Download</p>
              <h2 class="mt-4 text-2xl font-semibold text-[var(--ink)]">I'll publish signed downloads through GitHub Releases.</h2>
              <p class="mt-3 max-w-2xl text-sm leading-6 text-[var(--muted)]">
                I've already configured this page for OS-aware release assets. Until signed binaries are published, the primary action stays disabled and the source remains available.
              </p>
            </div>
            <div class="flex flex-wrap gap-3">
              <DownloadButton
                client:load
                repo={app.repo}
                status={app.versionStatus}
                assetPatterns={app.releaseAssets}
                fallbackUrl={app.repo}
                label={app.primaryCta}
              />
              <a href={app.repo} class="focus-ring secondary-cta" target="_blank" rel="noreferrer">
                {app.secondaryCta}
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</SiteLayout>
