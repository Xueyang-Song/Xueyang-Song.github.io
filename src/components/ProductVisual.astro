---
import type { AppConfig } from "../data/site";

type Props = {
  app: AppConfig;
};

const { app } = Astro.props;
const isPaperPilot = app.slug === "paper-pilot";
const accent = isPaperPilot ? "#58c7c9" : "#94b99f";
const secondary = isPaperPilot ? "#d28a55" : "#7aa7d9";
const viewLabels = isPaperPilot
  ? ["Crawl", "Corpus", "Brief"]
  : ["Notebook", "Kernel", "Model"];
---

<div class="atlas-panel max-w-full p-4" style={`--product-accent: ${accent}; --product-secondary: ${secondary};`}>
  <div class="pointer-events-none absolute -right-12 -top-12 h-44 w-44 rounded-full border border-[var(--product-accent)]/20"></div>
  <div class="pointer-events-none absolute bottom-8 left-8 h-24 w-24 rounded-full border border-[var(--product-secondary)]/18"></div>
  <div class="relative z-10 rounded-lg border border-white/12 bg-[#071318] p-3 shadow-2xl shadow-black/30">
    <div class="flex items-center gap-2 border-b border-white/10 pb-3">
      <span class="h-3 w-3 rounded-full bg-[#c97166]"></span>
      <span class="h-3 w-3 rounded-full bg-[#e2b86f]"></span>
      <span class="h-3 w-3 rounded-full bg-[#94b99f]"></span>
      <span class="ml-auto h-2 w-24 rounded-full bg-white/12"></span>
    </div>

    <div class="mt-4 grid min-h-60 min-w-0 grid-cols-[0.34fr_minmax(0,0.66fr)] gap-3">
      <aside class="rounded-md border border-white/10 bg-white/[0.045] p-3">
        <span class="block h-2 w-14 rounded-full" style={`background: ${accent}`}></span>
        <div class="mt-4 space-y-2">
          {viewLabels.map((label) => (
            <div class="rounded-md border border-white/8 bg-white/[0.055] p-2">
              <span class="block text-[0.58rem] font-black uppercase tracking-[0.14em] text-white/54">{label}</span>
            </div>
          ))}
        </div>
      </aside>

      <div class="grid min-w-0 gap-3">
        <div class="rounded-md border border-white/10 bg-white/[0.035] p-3">
          <div class="flex items-center justify-between gap-3">
            <span class="h-2.5 w-24 rounded-full" style={`background: ${accent}`}></span>
            <span class="h-7 w-16 rounded-md bg-white/8"></span>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-2">
            <span class="h-16 rounded-md border border-white/8 bg-[rgba(88,199,201,0.08)]"></span>
            <span class="h-16 rounded-md border border-white/8 bg-[rgba(122,167,217,0.08)]"></span>
            <span class="h-16 rounded-md border border-white/8 bg-[rgba(210,138,85,0.09)]"></span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-md border border-white/10 bg-white/[0.035] p-3">
            <span class="block h-2.5 w-16 rounded-full bg-white/18"></span>
            <span class="mt-3 block h-20 rounded-md border border-white/8 bg-white/[0.04]"></span>
          </div>
          <div class="rounded-md border border-white/10 bg-white/[0.035] p-3">
            <span class="block h-2.5 w-20 rounded-full bg-white/18"></span>
            <div class="mt-4 space-y-2">
              <span class="block h-2 rounded-full bg-white/16"></span>
              <span class="block h-2 w-5/6 rounded-full bg-white/12"></span>
              <span class="block h-2 w-3/4 rounded-full bg-white/12"></span>
            </div>
          </div>
        </div>

        <div class="rounded-md border p-3 text-xs font-bold" style={`border-color: ${accent}44; background: ${accent}14; color: ${accent};`}>
          {isPaperPilot
            ? "Literature signals flow into project-scoped artifacts."
            : "Notebook context stays local before model guidance leaves the workspace."}
        </div>
      </div>
    </div>
  </div>

  <div class="relative z-10 mt-4 grid grid-cols-3 gap-2 text-[0.65rem] font-black uppercase tracking-[0.14em] text-white/50">
    <span>Local</span>
    <span>Traceable</span>
    <span>Approved</span>
  </div>
</div>
