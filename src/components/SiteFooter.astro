---
import { profile } from "../data/site";
---

<footer class="border-t border-[var(--line)] bg-[rgba(6,16,20,0.9)]">
  <div class="container-shell flex flex-col gap-5 py-8 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-extrabold tracking-[0.14em] text-[var(--ink)] uppercase">{profile.name}</p>
      <p class="mt-1 max-w-xl text-sm text-[var(--muted)]">{profile.tagline}</p>
    </div>
    <div class="flex flex-wrap gap-4 text-sm font-bold text-[var(--muted)]">
      {profile.links.map((link) => (
        <a class="focus-ring atlas-link rounded-sm transition hover:text-[var(--teal)]" href={link.href} target="_blank" rel="noreferrer">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
